-- allium: 1
-- shell-config.allium

-- Scope: Shell integration and configuration management
-- Includes: Global config, per-directory state, resolution cascades,
--           shell completions, conversation fuzzy picker, prompt prefix composition
-- Excludes:
--   - Conversation content and lifecycle (see conversation.allium)
--   - Loop execution (see loop.allium)
--   - Sandbox internals (see sandbox.allium)


-- ==========================================================================
-- Configuration
-- ==========================================================================

-- Global configuration: user preferences that apply across all directories.
entity GlobalConfig {
    sandbox_enabled: Boolean
    sandbox_name: String
    default_agent: claude | codex | gemini
    discord_bots: Map<String, BotProfile>

    -- defaults
    default sandbox_enabled = true
    default sandbox_name = "default"
    default default_agent = claude
    default discord_bots = {}
}

-- Per-directory state: overrides that apply to a specific working directory.
entity DirectoryState {
    directory: Directory
    active_conversation: String?
    agent: String?
    model: String?
    sandbox: String?
    discord_destination: DiscordDestination?
    receive_all: Boolean?
    bot: String?
    dir_id: String?
}

-- Where Discord responses are delivered for this directory's conversations.
-- Can be a channel ID or a DM to a specific user.
-- Default: DM to the first user in the bot's allowed_users list.
value DiscordDestination {
    kind: channel | dm
    target: String                                   -- channel ID or user ID
}


-- ==========================================================================
-- Resolution cascades
-- ==========================================================================

-- Backend resolution: CLI flag > directory state > global config.
-- This determines which LLM backend handles a command.
rule ResolveBackend {
    when: ResolveBackend(cli_agent, directory_state, global_config)

    ensures: ResolvedBackend(
        backend:
            if cli_agent != null:
                cli_agent
            else if directory_state.agent != null:
                directory_state.agent
            else:
                global_config.default_agent
    )
}

-- Model resolution: CLI flag > directory state > backend default.
-- Determines which specific model to use for a command.
rule ResolveModel {
    when: ResolveModel(cli_model, directory_state)

    ensures: ResolvedModel(
        model:
            if cli_model != null:
                cli_model
            else if directory_state.model != null:
                directory_state.model
            else:
                null    -- use backend default
    )
}

-- Sandbox resolution: --no-sandbox > CLI --sandbox > directory state > global config.
-- Determines whether and which sandbox to use.
rule ResolveSandbox {
    when: ResolveSandbox(no_sandbox, cli_sandbox, directory_state, global_config)

    ensures: ResolvedSandbox(
        sandbox:
            if no_sandbox:
                null
            else if cli_sandbox != null:
                cli_sandbox
            else if directory_state.sandbox != null:
                directory_state.sandbox
            else if global_config.sandbox_enabled:
                global_config.sandbox_name
            else:
                null
    )
}

-- Discord destination resolution: CLI -d > directory state > default (DM to first allowed user).
-- Determines where Discord responses are delivered.
rule ResolveDiscordDestination {
    when: ResolveDiscordDestination(cli_destination, directory_state, bot_profile)

    ensures: ResolvedDiscordDestination(
        destination:
            if cli_destination != null:
                cli_destination
            else if directory_state.discord_destination != null:
                directory_state.discord_destination
            else:
                DiscordDestination(kind: dm, target: bot_profile.allowed_users.first)
    )
}

-- Receive-all resolution: CLI --receive-all > directory state > false.
-- Determines whether the bot processes all messages in a channel (without @mention).
rule ResolveReceiveAll {
    when: ResolveReceiveAll(cli_receive_all, directory_state)

    ensures: ResolvedReceiveAll(
        receive_all:
            if cli_receive_all != null:
                cli_receive_all
            else if directory_state.receive_all != null:
                directory_state.receive_all
            else:
                false
    )
}

-- Bot mirror resolution: --no-bot (force off) > CLI --bot > directory state > null.
-- Determines which bot profile is used to mirror CLI/loop output to Discord.
-- When set, messages and responses are sent to the bot's Discord destination.
rule ResolveBotMirror {
    when: ResolveBotMirror(no_bot, cli_bot, directory_state)

    ensures: ResolvedBotMirror(
        bot:
            if no_bot:
                null
            else if cli_bot != null:
                cli_bot
            else if directory_state.bot != null:
                directory_state.bot
            else:
                null
    )
}

-- Prompt prefix resolution: CLI --prompt <name> resolves to saved prompt body.
-- No directory-state fallback: prompt prefix is per-invocation only.
rule ResolvePromptPrefix {
    when: ResolvePromptPrefix(cli_prompt_name)

    ensures: ResolvedPromptPrefix(
        prompt_body:
            if cli_prompt_name != null:
                prompt_body_for_name(cli_prompt_name)
            else:
                null
    )
}

-- Outgoing message composition for top-level send:
--   prompt + message => "prompt\n\nmessage"
--   prompt only      => "prompt"
--   message only     => "message"
rule ComposeOutgoingMessage {
    when: ComposeOutgoingMessage(prompt_body, raw_message)

    ensures: ComposedMessage(
        message:
            if prompt_body != null and raw_message != null:
                prompt_body + "\n\n" + raw_message
            else if prompt_body != null:
                prompt_body
            else:
                raw_message
    )
}


-- ==========================================================================
-- State persistence
-- ==========================================================================

-- After sending a message or completing a loop, save the active settings
-- back to directory state so they persist across invocations.
rule PersistDirectoryState {
    when: PersistDirectoryState(directory, conversation_name, backend_name, model_name, sandbox_name, discord_destination, receive_all, bot)

    ensures: directory_state.active_conversation = conversation_name
    ensures: directory_state.agent = backend_name
    ensures: directory_state.model = model_name
    ensures: directory_state.sandbox = sandbox_name
    ensures: directory_state.discord_destination = discord_destination
    ensures: directory_state.receive_all = receive_all
    ensures: directory_state.bot = bot
}


-- ==========================================================================
-- Shell integration
-- ==========================================================================

-- Generate shell completion scripts for a given shell type.
-- Outputs a script that integrates clap completions with fuzzy picking.
value ShellType {
    kind: bash | zsh | fish
}

rule GenerateCompletions {
    when: GenerateCompletions(shell_type)

    ensures: CompletionScript(
        shell: shell_type,
        content: generate_completion_script(shell_type)
    )
}

-- Fuzzy picker for conversation selection.
-- Presents all conversations in the current directory with the active one marked.
rule FuzzyPickConversation {
    when: FuzzyPickConversation(directory)

    requires: directory.conversations.count > 0

    let items = directory.conversations
        .sorted_by_name
        .map(c =>
            if c = directory.active_conversation:
                "* " + c.name
            else:
                "  " + c.name
        )

    ensures: PickerPresented(items: items)
}

-- User selects a conversation from the picker.
-- The picker updates directory state directly (calls set_active).
rule ConversationPicked {
    when: ConversationPicked(directory, selected_name)

    requires: exists Conversation with directory = directory and name = selected_name

    ensures: directory.active_conversation = Conversation with name = selected_name
    ensures: StateCommitted(directory)
}

-- Prompt completion is opt-in: only when completing the --prompt flag value.
-- Completion candidates are prompt names (not prompt bodies).
rule CompletePromptFlagValues {
    when: CompletePromptFlagValues()

    ensures: CompletionCandidates(
        flag: "--prompt",
        values: Prompt.sorted_by_name.map(p => p.name)
    )
}


-- ==========================================================================
-- Status display
-- ==========================================================================

-- Show the current directory's active settings.
rule ShowStatus {
    when: ShowStatus(directory)

    let state = DirectoryState with directory = directory

    ensures: StatusReport(
        directory_path: directory.path,
        config_path: breo_config_dir,
        conversations_path: directory_conversations_path,
        active_conversation: state.active_conversation,
        agent: state.agent,
        model: state.model,
        sandbox: state.sandbox,
        discord_destination: state.discord_destination,
        receive_all: state.receive_all,
        bot: state.bot
    )
}


-- ==========================================================================
-- Black boxes
-- ==========================================================================

deferred generate_completion_script    -- shell-specific completion script generation
deferred breo_config_dir               -- ~/.config/breo
deferred prompt_body_for_name          -- prompt lookup by name in prompts.toml
deferred directory_conversations_path  -- ~/.config/breo/conversations/<dir-id>


-- ==========================================================================
-- Resolved decisions
-- ==========================================================================

-- Per-directory state now includes a preferred model (in addition to agent).
--   Resolution cascade: CLI --model > directory state > backend default.
-- Per-directory state includes a Discord destination (channel or DM).
--   Resolution cascade: CLI -d > directory state > default (DM to first allowed user).
--   Accepted values: a channel ID (delivers to channel) or "dm" (delivers via DM).
--   Default is DM to the first user in the bot's allowed_users list.
-- Per-directory state includes receive_all (whether bot processes all channel messages).
--   Resolution cascade: CLI --receive-all > directory state > false.
-- Auto-push has been removed. Use `breo git push` and `breo git pull` for manual sync.
-- Per-directory state includes bot (which bot profile mirrors CLI/loop output to Discord).
--   Resolution cascade: --no-bot (force off) > CLI --bot > directory state > null (no mirroring).
--   --no-bot clears the bot from state (persists the removal).
-- Prompt prefix is opt-in via --prompt <name>; no automatic prompt-body insertion
--   in shell completion.
-- Shell completion for --prompt returns prompt names only.
-- Conversation fuzzy picker filters by conversation name only. Content search is out of scope.
-- No per-directory config files. Global config (~/.config/breo/config.toml) only.

-- ==========================================================================
-- Conversation management
-- ==========================================================================

-- Rename a conversation without losing history.
-- If the renamed conversation is the active one, the active reference is updated.
rule RenameConversation {
    when: RenameConversation(directory, old_name, new_name)

    requires: exists Conversation with directory = directory and name = old_name
    requires: not exists Conversation with directory = directory and name = new_name

    ensures: Conversation with name = old_name is renamed to new_name
    ensures: if directory.active_conversation = old_name:
        directory.active_conversation = new_name
    ensures: StateCommitted(directory)
}
