-- allium: 1
-- claws.allium

-- Scope: Discord bridge for breo — chat with breo via DMs or channel mentions
-- Includes: Discord message handling, response delivery, configuration commands
-- Excludes:
--   - Conversation lifecycle and message exchange logic (see conversation.allium)
--   - Sandbox execution (see sandbox.allium)
--   - Shell integration (see shell-config.allium)
-- Dependencies: Conversation, Backend, Model, Directory from conversation.allium
--              DirectoryState from shell-config.allium


-- The running Discord bot instance, bound to a directory's settings at startup.
-- Discord credentials are read from the breo global config file (~/.config/breo/config.toml).
entity Bot {
    directory: Directory
    conversation: Conversation
    backend: Backend
    model: Model?
    sandbox: Sandbox?
    status: running | stopped
}


-- ==========================================================================
-- Bot lifecycle
-- ==========================================================================

-- Starting the bot. Inherits the directory's active conversation, agent,
-- model, and sandbox — same resolution as `breo <message>`.
rule StartBot {
    when: StartBot(directory)

    let config = GlobalConfig
    let state = DirectoryState with directory = directory

    requires: config.discord_token != null

    ensures: Bot.created(
        directory: directory,
        conversation: directory.active_conversation,
        backend: ResolvedBackend(state),
        model: ResolvedModel(state),
        sandbox: ResolvedSandbox(state),
        status: running
    )
    ensures: BotConnected(bot)
}

rule StopBot {
    when: StopBot(bot)

    requires: bot.status = running

    ensures: bot.status = stopped
    ensures: BotDisconnected(bot)
}


-- ==========================================================================
-- Message handling
-- ==========================================================================

-- A Discord message directed at the bot (DM or @mention in a channel).
-- All messages go to the bot's current conversation regardless of source.
-- Only allowed users can interact with the bot.
rule HandleDiscordMessage {
    when: DiscordMessageReceived(bot, message, source)

    requires: bot.status = running
    requires: message.source.user_id in config.discord_allowed_users

    -- Delegate to breo's SendMessage (conversation.allium)
    ensures: SendMessage(
        directory: bot.directory,
        conversation_name: bot.conversation.name,
        message: message.content,
        model: bot.model,
        backend: bot.backend,
        attachments: []
    )

    -- Deliver the response back to Discord
    let response = bot.conversation.exchanges.last.assistant_response
    let chunks = split_message(response, 2000)

    ensures:
        for chunk in chunks:
            DiscordMessageSent(
                target: message.source,
                content: chunk
            )
}

-- Where a Discord message came from (DM or channel).
value MessageSource {
    kind: direct_message | channel_mention
    channel_id: String
    user_id: String
}


-- ==========================================================================
-- Configuration commands (nice-to-have)
-- ==========================================================================

-- Reject messages from unauthorized users.
rule RejectUnauthorizedMessage {
    when: DiscordMessageReceived(bot, message, source)

    requires: bot.status = running
    requires: message.source.user_id not in config.discord_allowed_users

    ensures: DiscordMessageSent(
        target: message.source,
        content: "Access denied."
    )
}

-- All bot commands require the user to be in the allowed list.
-- This guard applies to every BotCommand rule below.

-- Switch the active conversation from Discord.
rule BotSwitchConversation {
    when: BotCommand(bot, "switch", conversation_name)

    requires: bot.status = running
    requires: command.source.user_id in config.discord_allowed_users
    requires: exists Conversation with directory = bot.directory and name = conversation_name

    ensures: bot.conversation = Conversation with name = conversation_name
    ensures: directory.active_conversation = bot.conversation
    ensures: StateCommitted(bot.directory)
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Switched to conversation: " + conversation_name
    )
}

-- Switch the backend agent from Discord.
rule BotSwitchAgent {
    when: BotCommand(bot, "agent", agent_name)

    requires: bot.status = running
    requires: command.source.user_id in config.discord_allowed_users
    requires: agent_name in { "claude", "codex", "gemini" }

    ensures: bot.backend = Backend with name = agent_name
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Switched to agent: " + agent_name
    )
}

-- Switch the model from Discord.
rule BotSwitchModel {
    when: BotCommand(bot, "model", model_name)

    requires: bot.status = running
    requires: command.source.user_id in config.discord_allowed_users

    ensures: bot.model = Model with name = model_name
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Switched to model: " + model_name
    )
}

-- Show current bot status.
rule BotStatus {
    when: BotCommand(bot, "status", _)

    requires: bot.status = running
    requires: command.source.user_id in config.discord_allowed_users

    ensures: DiscordMessageSent(
        target: command.source,
        content: "conversation: " + bot.conversation.name +
                 "\nagent: " + bot.backend.name +
                 "\nmodel: " + (bot.model.name ?? "default") +
                 "\nsandbox: " + (bot.sandbox.name ?? "none")
    )
}

-- List available conversations.
rule BotListConversations {
    when: BotCommand(bot, "list", _)

    requires: bot.status = running
    requires: command.source.user_id in config.discord_allowed_users

    let names = bot.directory.conversations
        .sorted_by_name
        .map(c =>
            if c = bot.conversation:
                "* " + c.name
            else:
                "  " + c.name
        )

    ensures: DiscordMessageSent(
        target: command.source,
        content: names.join("\n")
    )
}

-- Create a new conversation and switch to it.
rule BotNewConversation {
    when: BotCommand(bot, "new", conversation_name)

    requires: bot.status = running
    requires: command.source.user_id in config.discord_allowed_users
    requires: not exists Conversation with directory = bot.directory and name = conversation_name

    ensures: Conversation.created(
        name: conversation_name,
        directory: bot.directory,
        exchanges: [],
        content: "# Conversation: " + conversation_name
    )
    ensures: bot.conversation = Conversation with name = conversation_name
    ensures: bot.directory.active_conversation = bot.conversation
    ensures: StateCommitted(bot.directory)
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Created and switched to conversation: " + conversation_name
    )
}

-- Compact the current conversation.
rule BotCompact {
    when: BotCommand(bot, "compact", _)

    requires: bot.status = running
    requires: command.source.user_id in config.discord_allowed_users
    requires: bot.conversation.exchange_count > 0

    ensures: CompactConversation(bot.directory, bot.conversation.name)
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Compacted conversation: " + bot.conversation.name
    )
}


-- ==========================================================================
-- Black boxes
-- ==========================================================================

deferred split_message               -- split text into chunks of at most N characters
deferred BotConnected                -- establish Discord websocket connection
deferred BotDisconnected             -- close Discord websocket connection


-- ==========================================================================
-- Resolved decisions
-- ==========================================================================

-- All messages (DM and channel mention) go to the same conversation.
--   The bot is bound to one directory and one conversation at startup.
-- Long responses are split into multiple Discord messages (2000 char limit).
-- Configuration commands are nice-to-have, not core functionality.
-- Bot commands use text prefixes (!switch, !agent, !status, etc.), not Discord
--   slash commands. Simpler, no Discord app registration needed.
-- No file attachment support. Messages only.
-- Configuration changes from Discord persist to directory state, so the next
--   `breo` CLI command in the same directory picks up the changes.
