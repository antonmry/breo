-- allium: 1
-- claws.allium

-- Scope: Discord bridge for breo — chat with breo via DMs or channel mentions,
--        plus scheduled message execution via cron
-- Includes: Discord message handling, response delivery, configuration commands,
--           multi-bot support, cron scheduling, one-shot and periodic execution,
--           overlap protection
-- Excludes:
--   - Conversation lifecycle and message exchange logic (see conversation.allium)
--   - Sandbox execution (see sandbox.allium)
--   - Shell integration (see shell-config.allium)
-- Dependencies: Conversation, Backend, Model, Directory from conversation.allium
--              DirectoryState, GlobalConfig from shell-config.allium


-- ==========================================================================
-- Bot configuration
-- ==========================================================================

-- A named bot profile defined in the config file.
-- Multiple bots can be configured, each with its own token, guild, and access list.
-- Example config:
--   [discord.bots.mybot]
--   bot_token = "..."
--   guild_id = "..."
--   allowed_users = ["..."]
value BotProfile {
    name: String
    bot_token: String
    guild_id: String?
    allowed_users: List<String>
}


-- ==========================================================================
-- Bot entity
-- ==========================================================================

-- The running Discord bot instance, bound to a directory's settings at startup.
-- Created from a named BotProfile in the config file.
entity Bot {
    profile: BotProfile
    directory: Directory
    conversation: Conversation
    backend: Backend
    model: Model?
    sandbox: Sandbox?
    destination: DiscordDestination
    receive_all: Boolean
    last_user_id: String?
    status: running | stopped
}


-- ==========================================================================
-- Bot lifecycle
-- ==========================================================================

-- List configured bots: `breo claws list`.
-- Shows all bot profiles defined in the config file.
rule ListBots {
    when: ListBots()

    let config = GlobalConfig

    requires: config.discord_bots.count > 0

    ensures:
        for profile in config.discord_bots:
            BotListed(
                name: profile.name,
                guild_id: profile.guild_id
            )
}

-- Starting a bot by name: `breo claws <bot-name>` (required, no default).
-- The bot name argument supports shell auto-completion from configured profiles.
-- Looks up the named profile from config, inherits the directory's active
-- conversation, agent, model, and sandbox.
rule StartBot {
    when: StartBot(directory, bot_name)

    requires: bot_name != null

    let config = GlobalConfig
    let state = DirectoryState with directory = directory
    let profile = config.discord_bots with name = bot_name

    requires: profile != null

    ensures: Bot.created(
        profile: profile,
        directory: directory,
        conversation: directory.active_conversation,
        backend: ResolvedBackend(state),
        model: ResolvedModel(state),
        sandbox: ResolvedSandbox(state),
        destination: ResolvedDiscordDestination(state, profile),
        receive_all: ResolvedReceiveAll(state),
        last_user_id: null,
        status: running
    )
    ensures: BotConnected(bot)
    ensures: CronLoopStarted(bot)
}

rule StopBot {
    when: StopBot(bot)

    requires: bot.status = running

    ensures: bot.status = stopped
    ensures: BotDisconnected(bot)
}


-- ==========================================================================
-- Message handling
-- ==========================================================================

-- A Discord message directed at the bot (DM or @mention in a channel).
-- All messages go to the bot's current conversation regardless of source.
-- Only allowed users (per bot profile) can interact with the bot.
-- The bot tracks the last authorized user ID for cron DM delivery fallback.
rule HandleDiscordMessage {
    when: DiscordMessageReceived(bot, message, source)

    requires: bot.status = running
    requires: message.source.user_id in bot.profile.allowed_users
    requires: matches_destination(bot.destination, message.source)
    requires: should_process_message(bot, message.source)

    -- Track last authorized user for cron DM fallback
    ensures: bot.last_user_id = message.source.user_id

    -- Delegate to breo's SendMessage (conversation.allium)
    ensures: SendMessage(
        directory: bot.directory,
        conversation_name: bot.conversation.name,
        message: message.content,
        model: bot.model,
        backend: bot.backend,
        attachments: []
    )

    -- Deliver response to the configured destination (channel or DM)
    let response = bot.conversation.exchanges.last.assistant_response
    let chunks = split_message(response, 2000)

    ensures:
        for chunk in chunks:
            DeliverToDestination(bot.destination, chunk)
}

-- Where a Discord message came from (DM or channel).
value MessageSource {
    kind: direct_message | channel_mention
    channel_id: String
    user_id: String
}

-- Source filtering: each bot instance only processes messages from its destination.
-- Dm destination → only DMs. Channel(id) destination → only that channel.
-- Messages from other sources are silently ignored (no "Access denied").
rule matches_destination(destination, source) {
    match destination {
        Dm        => source.kind = direct_message
        Channel(id) => source.channel_id = id
    }
}

-- Message processing filter: in channels, require @mention unless receive_all is true.
-- DMs are always processed (they are inherently directed at the bot).
rule should_process_message(bot, source) {
    match source.kind {
        direct_message  => true
        channel_mention => true
        channel         => bot.receive_all
    }
}

-- Reject messages from unauthorized users.
rule RejectUnauthorizedMessage {
    when: DiscordMessageReceived(bot, message, source)

    requires: bot.status = running
    requires: message.source.user_id not in bot.profile.allowed_users

    ensures: DiscordMessageSent(
        target: message.source,
        content: "Access denied."
    )
}


-- ==========================================================================
-- Configuration commands
-- ==========================================================================

-- All bot commands require the user to be in the bot's allowed list.
-- Commands use text prefixes (!switch, !agent, etc.), not Discord slash commands.

-- Switch the active conversation from Discord.
rule BotSwitchConversation {
    when: BotCommand(bot, "switch", conversation_name)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users
    requires: exists Conversation with directory = bot.directory and name = conversation_name

    ensures: bot.conversation = Conversation with name = conversation_name
    ensures: bot.directory.active_conversation = bot.conversation
    ensures: StateCommitted(bot.directory)
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Switched to conversation: " + conversation_name
    )
}

-- Switch the backend agent from Discord.
rule BotSwitchAgent {
    when: BotCommand(bot, "agent", agent_name)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users
    requires: agent_name in { "claude", "codex", "gemini" }

    ensures: bot.backend = Backend with name = agent_name
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Switched to agent: " + agent_name
    )
}

-- Switch the model from Discord.
rule BotSwitchModel {
    when: BotCommand(bot, "model", model_name)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users

    ensures: bot.model = Model with name = model_name
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Switched to model: " + model_name
    )
}

-- Switch the Discord destination (channel or DM) from Discord.
-- Accepts a channel ID or "dm" (DM to first allowed user).
rule BotSwitchDestination {
    when: BotCommand(bot, "destination", target)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users

    let new_destination =
        if target = "dm":
            DiscordDestination(kind: dm, target: bot.profile.allowed_users.first)
        else:
            DiscordDestination(kind: channel, target: target)

    ensures: bot.destination = new_destination
    ensures: directory_state.discord_destination = new_destination
    ensures: StateCommitted(bot.directory)
    ensures: DiscordMessageSent(
        target: command.source,
        content:
            if target = "dm":
                "Destination set to: DM"
            else:
                "Destination set to: channel " + target
    )
}

-- Show current bot status.
rule BotStatus {
    when: BotCommand(bot, "status", _)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users

    let destination_display =
        if bot.destination.kind = dm:
            "dm"
        else:
            "channel " + bot.destination.target

    ensures: DiscordMessageSent(
        target: command.source,
        content: "bot: " + bot.profile.name +
                 "\ndirectory: " + bot.directory.path +
                 "\nconversation: " + bot.conversation.name +
                 "\nagent: " + bot.backend.name +
                 "\nmodel: " + (bot.model.name ?? "default") +
                 "\nsandbox: " + (bot.sandbox.name ?? "none") +
                 "\ndestination: " + destination_display +
                 "\nreceive_all: " + bot.receive_all
    )
}

-- List available conversations.
rule BotListConversations {
    when: BotCommand(bot, "list", _)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users

    let names = bot.directory.conversations
        .sorted_by_name
        .map(c =>
            if c = bot.conversation:
                "* " + c.name
            else:
                "  " + c.name
        )

    ensures: DiscordMessageSent(
        target: command.source,
        content: names.join("\n")
    )
}

-- Create a new conversation and switch to it.
rule BotNewConversation {
    when: BotCommand(bot, "new", conversation_name)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users
    requires: not exists Conversation with directory = bot.directory and name = conversation_name

    ensures: Conversation.created(
        name: conversation_name,
        directory: bot.directory,
        exchanges: [],
        content: "# Conversation: " + conversation_name
    )
    ensures: bot.conversation = Conversation with name = conversation_name
    ensures: bot.directory.active_conversation = bot.conversation
    ensures: StateCommitted(bot.directory)
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Created and switched to conversation: " + conversation_name
    )
}

-- Toggle or set whether the bot receives all channel messages without @mention.
rule BotReceiveAll {
    when: BotCommand(bot, "receive-all", argument)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users

    let new_value =
        if argument = "on":
            true
        else if argument = "off":
            false
        else:
            not bot.receive_all    -- toggle

    ensures: bot.receive_all = new_value
    ensures: directory_state.receive_all = new_value
    ensures: StateCommitted(bot.directory)
    ensures: DiscordMessageSent(
        target: command.source,
        content:
            if new_value:
                "Receive all: on (processing all messages in channel)"
            else:
                "Receive all: off (only processing @mentions)"
    )
}

-- Compact the current conversation.
rule BotCompact {
    when: BotCommand(bot, "compact", _)

    requires: bot.status = running
    requires: command.source.user_id in bot.profile.allowed_users
    requires: bot.conversation.exchange_count > 0

    ensures: CompactConversation(bot.directory, bot.conversation.name)
    ensures: DiscordMessageSent(
        target: command.source,
        content: "Compacted conversation: " + bot.conversation.name
    )
}


-- ==========================================================================
-- Cron configuration
-- ==========================================================================

-- A scheduled task defined in .breo/cron.toml.
-- One-shot tasks have a fixed datetime. Periodic tasks have an interval.
--
-- The cron file should include a comment header explaining the format so that
-- LLM agents can read it and manage tasks autonomously:
--
--   # breo cron — scheduled messages for the claws Discord bot
--   #
--   # The claws bot polls this file every 10 seconds. When a task's next_run
--   # time has passed, the bot sends the message to breo (using the bot's active
--   # conversation and agent) and delivers the response to the bot's configured
--   # Discord destination (channel or DM, set via -d flag or !destination command).
--   #
--   # Fields:
--   #   name      — unique task identifier
--   #   message   — the message to send to breo (the LLM agent will execute this)
--   #   next_run  — ISO 8601 datetime for the next execution (e.g. 2026-02-24T09:00:00)
--   #   interval  — (optional) duration between runs (e.g. "24h", "1h", "30m")
--   #               if omitted, the task runs once and is removed
--   #   status    — task state: "pending" (waiting), "running" (in progress)
--   #               do not manually set to "running" — the bot manages this
--   #
--   # One-shot tasks are removed after execution.
--   # Periodic tasks get next_run recalculated (next_run + interval) automatically.
--   # To add a new task, append a [[task]] entry and the bot will pick it up.
--   # To cancel a task, delete its [[task]] entry.
--   #
--   # When scheduling a task, write the [[task]] entry to this file and reply to
--   # the user confirming the task has been scheduled, including the task name,
--   # next_run time, and whether it is periodic or one-shot.
--   #
--   # Example:
--   #
--   #   [[task]]
--   #   name = "daily-status"
--   #   message = "Check the logs and report any errors from the last 24 hours"
--   #   next_run = 2026-02-24T09:00:00
--   #   interval = "24h"
--   #   status = "pending"
--   #
--   #   [[task]]
--   #   name = "one-shot-reminder"
--   #   message = "Summarize the current state of the feature branch"
--   #   next_run = 2026-02-24T15:30:00
--   #   status = "pending"

entity CronTask {
    name: String
    message: String
    next_run: Timestamp
    interval: Duration?
    status: pending | running

    -- Derived
    is_due: next_run <= now
    is_periodic: interval != null
}

value CronFile {
    path: String                                     -- .breo/cron.toml
    tasks: List<CronTask>
}


-- ==========================================================================
-- Cron polling
-- ==========================================================================

-- The bot polls the cron file every 10 seconds for due tasks.
-- This runs as a background loop alongside the Discord message handler.
-- Tasks with status = running are skipped (overlap protection).
-- If .breo/cron.toml does not exist, it is created (including the .breo directory)
-- with the comment header explaining the format.
rule PollCronFile {
    when: CronPollTick(bot)

    requires: bot.status = running

    ensures: ensure_cron_file(bot.directory)
    let cron_file = load_cron_file(bot.directory)

    ensures:
        for task in cron_file.tasks:
            if task.is_due and task.status = pending:
                ExecuteCronTask(bot, task)
}

config {
    poll_interval: Duration = 10.seconds
}


-- ==========================================================================
-- Task execution
-- ==========================================================================

-- A due task fires: mark as running, send the message through breo,
-- deliver response to Discord.
-- Tasks already in running state are skipped by the poller, preventing
-- duplicate execution when a task takes longer than the poll interval.
rule ExecuteCronTask {
    when: ExecuteCronTask(bot, task)

    requires: task.status = pending
    requires: task.is_due

    -- Mark as running immediately to prevent overlap
    ensures: task.status = running
    ensures: save_cron_file(bot.directory)

    -- Send message through breo's active conversation
    ensures: SendMessage(
        directory: bot.directory,
        conversation_name: bot.conversation.name,
        message: task.message,
        model: bot.model,
        backend: bot.backend,
        attachments: []
    )

    -- Deliver response to the bot's configured destination (channel or DM)
    let response = bot.conversation.exchanges.last.assistant_response
    let chunks = split_message(response, 2000)

    ensures:
        for chunk in chunks:
            DeliverToDestination(bot.destination, chunk)

    ensures: CronTaskCompleted(bot, task)
}


-- ==========================================================================
-- Task completion and rescheduling
-- ==========================================================================

-- One-shot task: remove from the cron file after execution.
rule CompleteOneShot {
    when: CronTaskCompleted(bot, task)

    requires: not task.is_periodic

    ensures: not exists task
    ensures: save_cron_file(bot.directory)
}

-- Periodic task: calculate next_run, reset to pending, keep in the cron file.
rule ReschedulePeriodicTask {
    when: CronTaskCompleted(bot, task)

    requires: task.is_periodic

    ensures: task.status = pending
    ensures: task.next_run = task.next_run + task.interval
    ensures: save_cron_file(bot.directory)
}


-- ==========================================================================
-- Black boxes
-- ==========================================================================

deferred split_message               -- split text into chunks of at most N characters
deferred DeliverToDestination        -- send message to a DiscordDestination (channel or DM)
deferred BotConnected                -- establish Discord websocket connection
deferred BotDisconnected             -- close Discord websocket connection
deferred CronLoopStarted             -- start background cron polling loop
deferred ensure_cron_file            -- create .breo/ dir and cron.toml with comment header if missing
deferred load_cron_file              -- parse .breo/cron.toml into CronFile
deferred save_cron_file              -- write updated CronFile back to .breo/cron.toml


-- ==========================================================================
-- Resolved decisions
-- ==========================================================================

-- Multiple bots supported. Each is a named profile in config under [discord.bots.<name>].
--   Launch with `breo claws <bot-name>` (bot name is required, no default).
--   `breo claws list` shows all configured bots.
--   Bot name argument supports shell auto-completion from configured profiles.
--   Each profile has its own token, guild, and access list.
-- All messages (DM and channel mention) go to the bot's current conversation.
-- Long responses are split into multiple Discord messages (2000 char limit).
-- Configuration commands are nice-to-have, not core functionality.
-- Bot commands use text prefixes (!switch, !agent, !status, etc.), not Discord
--   slash commands. Simpler, no Discord app registration needed.
-- No file attachment support. Messages only.
-- Configuration changes from Discord persist to directory state, so the next
--   `breo` CLI command in the same directory picks up the changes.
-- Access control is per bot profile (each bot has its own allowed_users list).
-- Cron file lives at .breo/cron.toml in the repo (not in ~/.config/breo).
-- If the file or .breo/ directory doesn't exist, breo creates them on first poll
--   with the comment header so the agent knows the format.
-- The cron file includes a comment header explaining the format, so LLM agents
--   can read it and manage tasks autonomously via breo messages.
-- Polling interval is 10 seconds.
-- Tasks only send messages to breo (no shell commands).
-- Tasks always use the bot's active conversation. No per-task conversation targeting.
-- Responses (both interactive and cron) are delivered to the bot's configured
--   Discord destination — either a channel or DM. Set via -d flag or !destination.
--   Default is DM to the first user in the bot's allowed_users list.
--   Destination is stored in per-directory state and persists across invocations.
-- One-shot tasks are removed from the file after execution.
-- Periodic tasks get next_run recalculated (next_run + interval) and stay in the file.
-- The cron loop runs inside the claws bot process (no separate daemon).
-- Overlap protection: tasks are marked as "running" before execution.
--   The poller skips running tasks, preventing duplicate execution when
--   a task takes longer than the poll interval.
-- Cron task management is done by the LLM agent editing .breo/cron.toml,
--   not via Discord commands. The comment header in the file guides the agent.
-- receive_all controls whether the bot processes all channel messages or only @mentions.
--   Resolution cascade: CLI --receive-all > directory state > false.
--   Toggled via !receive-all [on|off] (omit argument to toggle). Persisted to state.
-- last_user_id tracks the most recent authorized user who interacted with the bot.
--   Used as fallback for cron task DM delivery when no explicit user_id is set on the task.
--   Updated on every authorized message. Skips the bot's own user ID.
-- Auto-push has been removed. Git commits are still automatic, but push/pull
--   are now manual via `breo git push` and `breo git pull`.
